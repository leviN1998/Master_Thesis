cmake ..
make

if [ -z "$1" ]; then
  echo "Usage: $0 <suffix>"
  exit 1
fi

SUFFIX="$1"
FILENAME="progressreport"
NEW_FILENAME="${FILENAME}-${SUFFIX}.pdf"

mv "${FILENAME}.pdf" "../${NEW_FILENAME}"
echo "Renamed ${FILENAME}.pdf to ${NEW_FILENAME}"

echo "deleting files..."
cp build ../build_cpy
rm -rf *
mv ../build_cpy ./build
echo "Files deleted and build directory restored."